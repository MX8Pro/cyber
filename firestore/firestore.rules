rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function isWorker() {
      return signedIn() && request.auth.token.role == 'worker';
    }

    function isSelfUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwnWorkerRecord() {
      return isWorker() && resource.data.authUid == request.auth.uid;
    }

    function isOwnShift() {
      return isWorker() && resource.data.workerAuthUid == request.auth.uid;
    }

    function isOwnTransaction() {
      return isWorker() && resource.data.workerAuthUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isSelfUser(userId);
      allow write: if false;
    }

    match /workers/{workerId} {
      allow read: if isAdmin() || isOwnWorkerRecord();
      allow write: if false;
    }

    match /shifts/{shiftId} {
      allow read: if isAdmin() || isOwnShift();
      allow write: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isOwnTransaction();
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /workerDevices/{deviceId} {
      allow read, write: if false;
    }

    match /syncReceipts/{receiptId} {
      allow read, write: if false;
    }

    match /secrets/{secretId} {
      allow read, write: if false;
    }

    match /system/{docId} {
      allow read, write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
